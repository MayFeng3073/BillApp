<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 顶部统计卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_corner_bg"
            android:padding="20dp"
            android:elevation="4dp"
            android:layout_marginBottom="16dp">

            <!-- 标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="记账统计"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <!-- 总金额 -->
            <TextView
                android:id="@+id/tvTotalAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¥0.00"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="16dp" />

            <!-- 收入支出统计 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvTotalIncome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="收入 ¥0.00"
                    android:textSize="16sp"
                    android:textColor="@color/income" />

                <TextView
                    android:id="@+id/tvTotalExpense"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="支出 ¥0.00"
                    android:textSize="16sp"
                    android:textColor="@color/expense" />

            </LinearLayout>

            <!-- 最新记录 -->
            <TextView
                android:id="@+id/tvLatestExpense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="最新记录：暂无记录"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:padding="12dp"
                android:background="@color/card_background"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- 输入区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_corner_bg"
            android:padding="20dp"
            android:elevation="4dp"
            android:layout_marginBottom="16dp">

            <!-- 金额输入 -->
            <EditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="金额"
                android:inputType="numberDecimal"
                android:layout_marginBottom="16dp"
                android:minHeight="48dp"/>

            <!-- 类别输入 -->
            <EditText
                android:id="@+id/etCategory"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="类别（早餐、交通等）"
                android:inputType="text"
                android:layout_marginBottom="16dp"
                android:minHeight="48dp"/>

            <!-- 备注输入 -->
            <EditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="备注（可选）"
                android:inputType="text"
                android:layout_marginBottom="16dp"
                android:minHeight="48dp"/>

            <!-- 收入支出选择 -->
            <RadioGroup
                android:id="@+id/rgType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/rbExpense"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="支出"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbIncome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="收入" />

            </RadioGroup>

            <!-- 原有添加记录按钮 -->
            <Button
                android:id="@+id/btnAddExpense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="添加记录"
                android:textSize="16sp"
                android:paddingVertical="12dp"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white" />

            <!-- 发送记账提醒通知按钮 -->
            <Button
                android:id="@+id/btnSendNotification"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="发送记账提醒通知"
                android:textSize="16sp"
                android:paddingVertical="12dp"
                android:backgroundTint="@color/secondary"
                android:textColor="@color/white"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 广播功能区域 -->
        <Button
            android:id="@+id/btn_send_broadcast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="发送账目更新广播"
            android:textSize="16sp"
            android:paddingVertical="12dp"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp"/>

        <TextView
            android:id="@+id/tv_broadcast_tip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="等待广播消息..."
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="16dp"
            android:textColor="@color/text_secondary"/>

        <!-- SERVICE 按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_start_service"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="启动后台任务"
                android:textSize="16sp"
                android:paddingVertical="12dp"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_stop_service"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="停止后台任务"
                android:textSize="16sp"
                android:paddingVertical="12dp"
                android:backgroundTint="@color/expense"
                android:textColor="@color/white"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_service_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="后台状态：未运行"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp"
            android:textColor="@color/text_secondary"/>

        <!-- 测试 ContentProvider 按钮 -->
        <Button
            android:id="@+id/btn_test_provider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="测试 CONTENTPROVIDER 插入数据"
            android:textSize="16sp"
            android:paddingVertical="12dp"
            android:backgroundTint="@color/secondary"
            android:textColor="@color/white"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"/>

        <!-- 记录列表标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="所有记录"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp"
            android:layout_marginHorizontal="16dp"/>

        <!-- RecyclerView列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:scrollbars="vertical" />

    </LinearLayout>
</ScrollView>